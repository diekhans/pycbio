#!/usr/bin/env python3
# Copyright 2006-2025 Mark Diekhans

import sys
import re
from os import path as osp
from collections import Counter
import argparse
from openpyxl import Workbook
from openpyxl.utils import get_column_letter

sys.path.insert(0, osp.normpath(osp.join(osp.dirname(__file__), "../lib")))
from pycbio.sys import cli
from pycbio.tsv import TsvReader

# AI co-author: Claude

# Excel sheet name constraints
MAX_SHEET_NAME_LEN = 31
INVALID_SHEET_CHARS = set(r'[]:*?/\\')

DEFAULT_MAX_WIDTH = 16

# extra space added to each column so proportional-font headers are not
# clipped by a fraction of a character
WIDTH_PADDING = 1

def parseArgs():
    desc = """Combine one or more TSV files into an XLSX workbook, with each
    TSV becoming a separate sheet.  Sheet names are derived from the input file
    names unless overridden with --name.  This is the inverse of xlsx-to-tsv.
    """
    parser = argparse.ArgumentParser(description=desc)
    parser.add_argument("--name", action="append", default=[], dest="names",
                        help="sheet name for the corresponding input file, in order; "
                        "may be repeated (default: derived from the file name)")
    parser.add_argument("--numbers", action="store_true",
                        help="convert cells that look like integers or floats to numbers "
                        "(default: all cells are written as text)")
    parser.add_argument("--max-width", type=int, default=DEFAULT_MAX_WIDTH, dest="maxWidth",
                        help="fit each column to its widest cell, up to this many characters "
                        "(default: %(default)s)")
    parser.add_argument("--header-subst", nargs=2, action="append", default=[], dest="headerSubs",
                        metavar=("PATTERN", "REPL"),
                        help="apply a regular expression substitution to every column header; "
                        "PATTERN is a Python regex and REPL its replacement; may be repeated "
                        "and are applied in order")
    parser.add_argument("--sheet-name-subst", nargs=2, action="append", default=[], dest="sheetNameSubs",
                        metavar=("PATTERN", "REPL"),
                        help="apply a regular expression substitution to every derived sheet name "
                        "(before sanitizing and uniquifying); PATTERN is a Python regex and REPL "
                        "its replacement; may be repeated and are applied in order")
    parser.add_argument("--no-header-normalize", action="store_false", dest="normalize",
                        help="do not normalize column headers to valid Python identifiers "
                        "(by default headers are normalized, after any --header-subst)")
    parser.add_argument("--pairs", action="store_true",
                        help="the input arguments are alternating SHEET_NAME TSV pairs rather "
                        "than a list of TSV files; may not be combined with --name")
    parser.add_argument("outXlsx",
                        help="output XLSX file")
    parser.add_argument("inTsvs", nargs="+",
                        help="one or more input TSV files, maybe compressed; with --pairs, "
                        "alternating SHEET_NAME TSV pairs")
    return cli.parseOptsArgsWithLogging(parser)

def sanitizeSheetName(name):
    "make a sheet name valid for Excel: drop invalid chars and truncate"
    cleaned = ''.join(c for c in name if c not in INVALID_SHEET_CHARS).strip()
    if cleaned == "":
        cleaned = "Sheet"
    return cleaned[:MAX_SHEET_NAME_LEN]

def uniqueSheetName(name, used):
    "ensure a sheet name is unique, appending a numeric suffix if needed"
    if name not in used:
        return name
    suffix = 2
    while True:
        candidate = f"{name[:MAX_SHEET_NAME_LEN - len(str(suffix)) - 1]}_{suffix}"
        if candidate not in used:
            return candidate
        suffix += 1

def validateArgs(outXlsx, inTsvs):
    "check the output extension and that input files exist"
    if not outXlsx.lower().endswith(('.xlsx', '.xlsm')):
        raise cli.CliError(f"Output file must have a .xlsx or .xlsm extension: {outXlsx}")
    for inTsv in inTsvs:
        if not osp.exists(inTsv):
            raise cli.CliError(f"Input file not found: {inTsv}")

def substSheetName(name, sheetNameSubs):
    "apply regex substitutions to a derived sheet name"
    for pattern, repl in sheetNameSubs:
        name = re.sub(pattern, repl, name)
    return name

def determineSheetNames(inTsvs, names, sheetNameSubs):
    "compute the sheet name to use for each input file"
    if len(names) not in (0, len(inTsvs)):
        raise cli.CliError(f"got {len(names)} --name options for {len(inTsvs)} input files; "
                           "specify one --name per input file or none")
    requested = names if names else [osp.splitext(osp.basename(f))[0] for f in inTsvs]
    requested = [substSheetName(name, sheetNameSubs) for name in requested]
    sheetNames = []
    used = set()
    for name in requested:
        sheetName = uniqueSheetName(sanitizeSheetName(name), used)
        used.add(sheetName)
        sheetNames.append(sheetName)
    return sheetNames

def toIdentifier(name):
    "convert a header to a valid Python identifier"
    ident = re.sub(r'\W', '_', name)
    if (ident == "") or ident[0].isdigit():
        ident = "_" + ident
    return ident

def transformHeaderName(name, headerSubs, normalize):
    "apply regex substitutions then optional identifier normalization to one header"
    for pattern, repl in headerSubs:
        name = re.sub(pattern, repl, name)
    return toIdentifier(name) if normalize else name

def transformHeader(header, inTsv, opts):
    "transform all header names and error on any resulting duplicates"
    newHeader = [transformHeaderName(c, opts.headerSubs, opts.normalize) for c in header]
    dups = sorted(name for name, cnt in Counter(newHeader).items() if cnt > 1)
    if dups:
        raise cli.CliError(f"duplicate column names after transformation in {inTsv}: "
                           + ", ".join(dups))
    return newHeader

def convertCell(value, numbers):
    "if numbers is set, convert an int- or float-looking cell to a number"
    if not numbers or value == "":
        return value
    try:
        return int(value)
    except ValueError:
        pass
    try:
        return float(value)
    except ValueError:
        return value

def accountWidths(widths, values):
    "grow the per-column max display widths to fit the given row values"
    for i, value in enumerate(values):
        length = len(str(value))
        if i >= len(widths):
            widths.append(length)
        elif length > widths[i]:
            widths[i] = length

def setColumnWidths(sheet, widths, maxWidth):
    "size each column to its widest cell, capped at maxWidth"
    for i, width in enumerate(widths):
        if width > 0:
            width = min(width, maxWidth) + WIDTH_PADDING
            sheet.column_dimensions[get_column_letter(i + 1)].width = width

def loadTsvIntoSheet(sheet, inTsv, opts):
    "read a TSV file and write its header and rows into a worksheet"
    reader = TsvReader(inTsv, allowEmpty=True)
    widths = []
    if len(reader.columns) > 0:
        header = transformHeader(list(reader.columns), inTsv, opts)
        sheet.append(header)
        accountWidths(widths, header)
    for row in reader:
        values = [convertCell(v, opts.numbers) for v in row]
        sheet.append(values)
        accountWidths(widths, values)
    setColumnWidths(sheet, widths, opts.maxWidth)

def buildWorkbook(inTsvs, sheetNames, opts):
    "build a workbook with one sheet per input file"
    workbook = Workbook()
    workbook.remove(workbook.active)  # drop the empty default sheet
    for inTsv, sheetName in zip(inTsvs, sheetNames):
        loadTsvIntoSheet(workbook.create_sheet(title=sheetName), inTsv, opts)
    return workbook

def resolveInputs(opts, positionals):
    "return (names, inTsvs) from a plain file list or --pairs alternating list"
    if not opts.pairs:
        return opts.names, positionals
    if opts.names:
        raise cli.CliError("--name may not be combined with --pairs")
    if len(positionals) % 2 != 0:
        raise cli.CliError("--pairs requires an even number of arguments: SHEET_NAME TSV ...")
    return positionals[0::2], positionals[1::2]

def tsvToXlsx(opts, outXlsx, positionals):
    names, inTsvs = resolveInputs(opts, positionals)
    validateArgs(outXlsx, inTsvs)
    sheetNames = determineSheetNames(inTsvs, names, opts.sheetNameSubs)
    workbook = buildWorkbook(inTsvs, sheetNames, opts)
    workbook.save(outXlsx)

def main():
    opts, args = parseArgs()
    with cli.ErrorHandler():
        tsvToXlsx(opts, args.outXlsx, args.inTsvs)


main()
